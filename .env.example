# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# PostgreSQL
POSTGRES_USER=foodai
POSTGRES_PASSWORD=foodai_password
POSTGRES_DB=foodai_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://foodai:foodai_password@db:5432/foodai_db

# Admin Telegram IDs (comma-separated)
ADMIN_IDS=123456789,987654321

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
